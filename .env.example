# ─────────────────────────────────────────────
#  Docustra — Environment Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── LLM Providers (free tiers) ───────────────
# Google Gemini: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq (fast inference, free tier): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Primary LLM provider: "gemini" | "groq" | "ollama"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
# For local Ollama (no API key needed): LLM_PROVIDER=ollama, LLM_MODEL=qwen3.5
OLLAMA_BASE_URL=http://localhost:11434

# ── Embeddings ────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu   # "cpu" | "mps" for Apple Silicon

# ── Vector Store (Qdrant) ─────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=docustra_docs

# ── Graph Store (Neo4j) ───────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=docustra_local

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Web Search Fallback (CRAG) ────────────────
# Tavily: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Observability (Arize Phoenix) ────────────
PHOENIX_HOST=localhost
PHOENIX_PORT=6006
ENABLE_TRACING=true

# ── API Server ────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# ── RAG Retrieval Config ─────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.7   # CRAG confidence threshold
CHUNK_SIZE=512
CHUNK_OVERLAP=64
